diff -urN a/source/FMCPCDReader.cpp b/source/FMCPCDReader.cpp
--- a/source/FMCPCDReader.cpp	2026-04-28 21:11:18.780705072 +0000
+++ b/source/FMCPCDReader.cpp	2026-04-28 21:11:18.909705979 +0000
@@ -1035,12 +1035,45 @@
     LOG( DBG1 ) << ind(2) << "Parsing of XML node 'hashtable'"
                 << " ... " << std::endl;
     
-    checkUnknownAttr( pNode, 3, "mask", "hashshift", "keysize" );
+    checkUnknownAttr( pNode, 7, "mask", "hashshift", "keysize",
+                      "external", "aging", "data_mem_id", "data_liodn_offs" );
 
     hashTable->mask      = std::strtoul( getAttr( pNode, "mask" ).c_str(), 0, 0 );
     hashTable->hashShift = std::strtoul( getAttr( pNode, "hashshift" ).c_str(), 0, 0 );
     hashTable->keySize   = std::strtoul( getAttr( pNode, "keysize" ).c_str(), 0, 0 );
 
+    // ASK extension: external/aging/data_mem_id/data_liodn_offs are optional.
+    // Defaults preserve the legacy MURAM-internal hashtable behavior.
+    hashTable->external      = false;
+    hashTable->aging         = false;
+    hashTable->dataMemId     = 0;
+    hashTable->dataLiodnOffs = 0;
+
+    {
+        std::string s = getAttr( pNode, "external" );
+        if ( !s.empty() ) {
+            hashTable->external = ( s == "yes" || s == "true" || s == "1" );
+        }
+    }
+    {
+        std::string s = getAttr( pNode, "aging" );
+        if ( !s.empty() ) {
+            hashTable->aging = ( s == "yes" || s == "true" || s == "1" );
+        }
+    }
+    {
+        std::string s = getAttr( pNode, "data_mem_id" );
+        if ( !s.empty() ) {
+            hashTable->dataMemId = std::strtoul( s.c_str(), 0, 0 );
+        }
+    }
+    {
+        std::string s = getAttr( pNode, "data_liodn_offs" );
+        if ( !s.empty() ) {
+            hashTable->dataLiodnOffs = std::strtoul( s.c_str(), 0, 0 );
+        }
+    }
+
     LOG( DBG1 ) << ind(-2) << "Done" << std::endl;
 
     return;
