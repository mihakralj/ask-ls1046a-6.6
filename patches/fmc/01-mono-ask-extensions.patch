+HTNode&
+CFMCModel::replicateHtNodes(const CTaskDef* pTaskDef, Port& port, HTNode& ref)
+{
+    uint32_t ii;
+    uint32_t index;
+
+    for( ii = 0; ii < port.htnodes.size(); ii++) {
+	if (all_htnodes[port.htnodes[ii]].name == ref.name) {
+	    return all_htnodes[port.htnodes[ii]];
+	}
+    }
+
+    unsigned int newIdx = FMBlock::assignIndex( all_htnodes );
+
+    HTNode& htNode = all_htnodes[newIdx];
+    ApplyOrder::Entry n1( ApplyOrder::HTNode, htNode.getIndex() );
+    applier.add_edge( n1, ApplyOrder::Entry( ApplyOrder::None, 0 ) );
+    port.htnodes.push_back(htNode.getIndex() );
+
+    htNode.name = ref.name;
+    htNode.maxNumOfKeys = ref.maxNumOfKeys;
+    htNode.statistics = ref.statistics;
+    htNode.hashResMask = ref.hashResMask;
+    htNode.matchKeySize = ref.matchKeySize;
+    htNode.hashShift = ref.hashShift;
+    htNode.kgHashShift = ref.kgHashShift;
+    for (ii = 0; ii < ref.keys.size(); ii++) {
+    htNode.keys.push_back(HTNode::CCData());
+    }
+    for (ii = 0; ii < ref.masks.size(); ii++) {
+    htNode.masks.push_back(HTNode::CCData());
+    }
+    for (ii = 0; ii < ref.nextEngines.size(); ii++) {
+    htNode.nextEngines.push_back(HTNode::CCNextEngine());
+    }
+
+    for (ii = 0; ii < ref.frag.size(); ii++) {
+	index = ref.frag[ii];
+	htNode.frag.push_back(index);
+    }
+    for (ii = 0; ii < ref.header.size(); ii++) {
+	index = ref.header[ii];
+    htNode.header.push_back(index);
+    }
+    for (ii = 0; ii < ref.indices.size(); ii++) {
+	index = ref.indices[ii];
+    htNode.indices.push_back(index);
+    }
+
+    htNode.nextEngineOnMiss = ref.nextEngineOnMiss;
+    htNode.fragOnMiss = ref.fragOnMiss;
+    htNode.headerOnMiss = ref.headerOnMiss;
+    htNode.port_signature = port.name;
+
+    ApplyOrder::Entry root( ApplyOrder::CCTree, port.getIndex() );
+
+    port.cctrees.push_back( htNode.getIndex() );
+    port.cctrees_type.push_back( e_FM_PCD_HASH );
+    port.hdrmanips.push_back( 0 );
+    return htNode;
+}
+
+CCNode&
+CFMCModel::replicateCCNodes(const CTaskDef* pTaskDef, Port& port, CCNode& ref)
+{
+    uint32_t ii;
+    uint32_t index;
+
+    for( ii = 0; ii < port.ccnodes.size(); ii++) {
+	if (all_ccnodes[port.ccnodes[ii]].name == ref.name) {
+	    return all_ccnodes[port.ccnodes[ii]];
+	}
+    }
+
+    unsigned int newIdx = FMBlock::assignIndex( all_ccnodes );
+
+    CCNode& ccNode = all_ccnodes[newIdx];
+
+    ApplyOrder::Entry n1( ApplyOrder::CCNode, ccNode.getIndex() );
+    applier.add_edge( n1, ApplyOrder::Entry( ApplyOrder::None, 0 ) );
+
+    port.ccnodes.push_back(ccNode.getIndex() );
+
+    ccNode.name = ref.name;
+    ccNode.maxNumOfKeys = ref.maxNumOfKeys;
+    ccNode.statistics = ref.statistics;
+    ccNode.maskSupport = ref.maskSupport;
+    ccNode.shared = 0;
+    ccNode.extract = ref.extract;
+    ccNode.keySize = ref.keySize;
+    ccNode.used_protocols.insert(ref.used_protocols.begin(), ref.used_protocols.end());
+    for (ii = 0; ii < ref.keys.size(); ii++) {
+    ccNode.keys.push_back(CCNode::CCData());
+    }
+    for (ii = 0; ii < ref.masks.size(); ii++) {
+    ccNode.masks.push_back(CCNode::CCData());
+    }
+    for (ii = 0; ii < ref.nextEngines.size(); ii++) {
+    ccNode.nextEngines.push_back(CCNode::CCNextEngine());
+    }
+    for (ii = 0; ii < ref.frag.size(); ii++) {
+	index = ref.frag[ii];
+	ccNode.frag.push_back(index);
+    }
+    for (ii = 0; ii < ref.header.size(); ii++) {
+	index = ref.header[ii];
+    ccNode.header.push_back(index);
+    }
+    for (ii = 0; ii < ref.indices.size(); ii++) {
+	index = ref.indices[ii];
+    ccNode.indices.push_back(index);
+    }
+    for (ii = 0; ii < ref.frameLength.size(); ii++) {
+	index = ref.frameLength[ii];
+    ccNode.frameLength.push_back(index);
+    }
+    ccNode.nextEngineOnMiss = ref.nextEngineOnMiss;
+    ccNode.fragOnMiss = ref.fragOnMiss;
+    ccNode.headerOnMiss = ref.headerOnMiss;
+    ccNode.port_signature = port.name;
+    port.cctrees.push_back( ccNode.getIndex() );
+    port.cctrees_type.push_back( e_FM_PCD_CC );
+    port.hdrmanips.push_back( 0 );
+    return ccNode;
+}
