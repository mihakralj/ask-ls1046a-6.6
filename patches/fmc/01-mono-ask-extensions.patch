+    /* Mono Gateway extensions: push hash buckets/contexts off-MURAM into
+     * DDR-backed USDPAA memory (kernel UAPI: ioc_fm_pcd_hash_table_params_t
+     * external_hash + external_hash_params, fm_pcd_ioctls.h:1530+).  Also
+     * enables key aging support (aging_support).  Without these, every
+     * hashtable falls back to the 384 KiB FMan internal MURAM and large
+     * PCD configs hit AllocStatsObjs / MatchTableSet allocation failures.
+     */
+    bool         external;       ///< true if hash buckets live in DDR (off-MURAM)
+    bool         aging;          ///< true to enable per-key aging tracking
+    unsigned int dataMemId;      ///< Memory partition ID for external hash buckets
+    unsigned int dataLiodnOffs;  ///< LIODN offset for external hash buckets
 };
 
