+    // ASK extensions: external/aging hashtable support. When external is true,
+    // the FMan PCD allocates the bucket array in DDR via USDPAA at the offset
+    // specified by dataLiodnOffs in memory partition dataMemId, instead of in
+    // on-chip MURAM (default). aging enables per-bucket aging metadata.
+    bool         external;
+    bool         aging;
+    unsigned int dataMemId;
+    unsigned int dataLiodnOffs;
+
     std::vector< CCData >       keys;   ///< The list of data entries
     std::vector< CCData >       masks;  ///< The list of masks corresponding to data entries
