# ASK (Application Solutions Kit) kernel config fragment for Linux 6.6.x LTS
# Append to your kernel defconfig or .config, then run: make olddefconfig
#
# Required: NXP LS1046A (or compatible Layerscape) with FMAN silicon
# These options enable the ASK fast-path hardware offload subsystem

# --- ASK Core Fast Path ---
CONFIG_CPE_FAST_PATH=y

# --- NXP SDK DPAA Ethernet (replaces mainline FSL_DPAA_ETH) ---
CONFIG_FSL_SDK_DPA=y
CONFIG_FSL_SDK_DPAA_ETH=y
CONFIG_FSL_DPAA_1588=y
CONFIG_FSL_DPAA_ETH_MAX_BUF_COUNT=640

# --- ASK Netfilter Extensions ---
CONFIG_NETFILTER_XT_QOSMARK=y
CONFIG_NETFILTER_XT_QOSCONNMARK=y

# --- IPsec Hardware Offload ---
CONFIG_INET_IPSEC_OFFLOAD=y

# --- Module versioning (required for out-of-tree ASK modules) ---
CONFIG_MODVERSIONS=y

# --- IMPORTANT: Disable mainline DPAA ETH if enabled ---
# CONFIG_FSL_DPAA_ETH is not set